{
  "buildCommand": "cd frontend-project && npm install && npm run build",
  "outputDirectory": "frontend-project/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
